# MongoDB (Atlas — URL-encode special chars in password, e.g. @ → %40)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/hautoria?retryWrites=true&w=majority&appName=Cluster0

# Server
PORT=3001
NODE_ENV=development
# On Vercel: set CLIENT_URL to https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change-this-refresh-secret-too
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend (Vite) — same-origin /api on Vercel; local Vite proxies /api → :3001
VITE_API_BASE_URL=/api

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Hautoria <noreply@hautoria.com>

# WhatsApp — order alerts to YOUR store number
# Option A: CallMeBot (easiest — free, no business account)
#   1. Add +34 644 71 71 07 on WhatsApp, send "I allow callmebot to send me messages"
#   2. Get your API key from CallMeBot
#   3. Set WHATSAPP_PROVIDER=callmebot
WHATSAPP_PROVIDER=callmebot
WHATSAPP_STORE_NUMBER=+923001234567
WHATSAPP_SUPPORT_NUMBER=+923001234567
WHATSAPP_CALLMEBOT_APIKEY=

# Option B: Meta WhatsApp Cloud API (production)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_API_TOKEN=your-meta-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Option C: Custom webhook (Twilio, etc.)
# WHATSAPP_PROVIDER=webhook
# WHATSAPP_API_URL=https://your-provider.com/send
# WHATSAPP_API_TOKEN=your-token

# Frontend WhatsApp link (customer support button)
VITE_WHATSAPP_NUMBER=+923001234567

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Store
STORE_NAME=Hautoria
STORE_TAGLINE=Crafted for Timeless Skin.
