{
  "name": "hautoria",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "dev:admin": "npx vite --config vite.admin.config.ts",
    "dev:server": "npx tsx watch server/src/index.ts",
    "dev:all": "npx concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "npx vite build",
    "build:admin": "npx vite build --config vite.admin.config.ts",
    "build:server": "npm run build --prefix server",
    "seed": "npx tsx server/scripts/seed.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "npx vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@gsap/react": "^2.1.2",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^11.5.4",
    "gsap": "^3.15.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lenis": "latest",
    "lucide-react": "0.522.0",
    "mongoose": "^8.9.5",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.18",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vercel/node": "^5.1.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "concurrently": "^9.1.2",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
}
